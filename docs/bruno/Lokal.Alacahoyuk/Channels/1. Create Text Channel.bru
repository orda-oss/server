meta {
  name: 1. Create Text Channel
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/channels
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "general",
    "kind": "text"
  }
}

script:post-response {
  const body = res.getBody();
  const status = res.getStatus();
  if (status === 200 || status === 201) {
    bru.setVar("channelId", body.data.id);
  }
}

settings {
  encodeUrl: true
}
